generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password     String
  profileImage String?
  createdAt    DateTime @default(now())
}

model MenuItem {
  id        Int      @id @default(autoincrement())
  name      String
  category  String
  isVeg     Boolean
  priceText String
  image     String
  createdAt DateTime @default(now())
}

model Reservation {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @default("")
  phone     String
  date      String
  time      String
  status    String   @default("Pending")
  customerId Int?
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?
  isPaid            Boolean  @default(false)
  amount            Int      @default(0)
  createdAt DateTime @default(now())
}

model RestaurantSettings {
  id             Int      @id @default(1)
  openTime       String   @default("18:00")
  closeTime      String   @default("23:00")
  gstEnabled     Boolean  @default(true)
  gstPercentage  Int      @default(18)
  platformFee    Int      @default(0)
  deliveryCharge Int      @default(0)
  tableBookingFee Int     @default(0)
  customFees     Json     @default("[]")
}

model SiteContent {
  id      Int  @id @default(1)
  seo     Json @default("{}")
  hero    Json
  about   Json
  online  Json
  call    Json
  event   Json
  promise Json
  footer  Json
  aboutH  Json @default("{}")
  contact Json @default("{}")
  eventsH Json @default("{}")
  galleryH Json @default("{}")
}

model GalleryImage {
  id        Int      @id @default(autoincrement())
  row       Int      @default(1)
  title     String   @default("")
  image     String
  createdAt DateTime @default(now())
}

model ContactRequest {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String
  message   String
  status    String   @default("Pending")
  createdAt DateTime @default(now())
}

model ChefSpecial {
  id        Int      @id @default(autoincrement())
  title     String
  hoverText String
  image     String
}

model ContentMenuCategory {
  id        Int      @id @default(autoincrement())
  name      String
  isEnabled Boolean  @default(true)
  image1    String
  image2    String
  image3    String
}

model Testimonial {
  id        Int      @id @default(autoincrement())
  name      String
  text      String
  image     String
}

model TicketEvent {
  id              Int      @id @default(autoincrement())
  title           String
  subtitle        String?
  location        String
  date            DateTime
  price           Int
  totalSeats      Int
  bookedSeats     Int      @default(0)
  image           String
  isEnabled       Boolean  @default(true)
  createdAt       DateTime @default(now())
}

model Customer {
  id              Int      @id @default(autoincrement())
  email           String   @unique
  password        String
  isSetupComplete Boolean  @default(false)
  fullName        String?
  mobile          String?
  location        String?
  liveLocation    String?
  deliveryLocation String?
  streetAddress   String?
  receiverName    String?
  receiverMobile  String?
  homeImage       String?
  profileImage    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TicketBooking {
  id              Int      @id @default(autoincrement())
  customerId      Int
  eventId         Int
  tickets         Int      @default(1)
  status          String   @default("Confirmed")
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?
  isPaid            Boolean  @default(false)
  createdAt       DateTime @default(now())
}

model Staff {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  password     String
  profileImage String?
  createdAt    DateTime @default(now())
}

model CredentialRequest {
  id          Int      @id @default(autoincrement())
  staffId     Int
  newUsername String
  newPassword String
  status      String   @default("Pending") // Pending, Approved, Rejected
  createdAt   DateTime @default(now())
}

model FoodOrder {
  id               Int      @id @default(autoincrement())
  customerId       Int
  items            Json     // Stores array of { id, name, priceText, quantity, isVeg, image }
  totalAmount      Int
  status           String   @default("Pending") // Pending, Approved, Out for Delivery, Delivered, Rejected, Cancelled
  paymentMethod    String   @default("Cash on Delivery")
  staffMessage     String?
  deliveryFriendId Int?
  customerLocation String?
  deliveryType     String   @default("Delivery") // Delivery or Pickup
  streetAddress    String?
  receiverName     String?
  receiverMobile   String?
  homeImage        String?
  feeBreakdown     Json     @default("{}")
  razorpayOrderId  String?
  razorpayPaymentId String?
  razorpaySignature String?
  isPaid           Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model DeliveryFriend {
  id              Int      @id @default(autoincrement())
  uniqueId        String   @unique
  password        String
  name            String
  email           String
  mobile          String
  idCardImage     String
  idCardNumber    String
  address         String
  resumeFile      String?
  profileImage    String?
  status          String   @default("Available") // Available, Delivering, On Leave
  availableSince  DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model DeliveryFriendRequest {
  id               Int      @id @default(autoincrement())
  deliveryFriendId Int
  newMobile        String?
  newEmail         String?
  newAddress       String?
  status           String   @default("Pending") // Pending, Approved, Rejected
  createdAt        DateTime @default(now())
}

